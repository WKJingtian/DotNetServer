{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Grpc": "Warning",
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Update": "Fatal",
        "Microsoft.EntityFrameworkCore.Database.Command": "Fatal",
        "Org.Apache.Rocketmq.Client": "Warning",
        "System": "Warning"
      }
    }
  },
  "Nacos": {
    "Listeners": [
      {
        "Optional": false,
        "DataId": "GameOutside",
        "Group": "BuildingGame"
      },
      {
        "Optional": false,
        "DataId": "MatchFunction",
        "Group": "BuildingGame"
      },
      {
        "Optional": false,
        "DataId": "GameOutsideEnvironment",
        "Group": "BuildingGame"
      },
      {
        "Optional": false,
        "DataId": "AssistActivity",
        "Group": "BuildingGame"
      }
    ],
    "ServiceName": "GameOutside",
    "ServerAddresses": [
      ""
    ],
    "DefaultTimeOut": 15000,
    "ConfigUseRpc": true
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080",
        "Protocols": "Http1"
      },
      "gRPC": {
        "Url": "https://0.0.0.0:4433",
        "Protocols": "Http2",
        "Certificate": {
          "Path": "/cert/tls.crt",
          "KeyPath": "/cert/tls.key"
        }
      }
    }
  },
  "ConnectionStrings": {
    "AssistActivity": "https://assist-activity"
  },
  "AllowedHosts": "*",
  "GameDataTable": {
    "EnableLocalCache": false,
    "ConfigFile": []
  }
}